# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS files ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data — raw and processed data are never committed (too large / private) ─────
data/raw/*
data/interim/*
data/processed/*
data/external/*

# Preserve directory structure with .gitkeep placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ── MLflow experiment tracking — local run artefacts ───────────────────────────
mlruns/
mlartifacts/

# ── Model artefacts ─────────────────────────────────────────────────────────────
*.joblib
*.pkl
*.pt
*.onnx

# ── Logs ────────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Jupyter ─────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDEs ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Coverage ────────────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Reports: figures and tables ARE committed so README images render on GitHub ─
# (Remove these lines only if the files become too large to track in git)
# reports/figures/*
# reports/tables/*
